{
  "name": "@superserve/example-loops",
  "version": "0.0.0",
  "private": true,
  "description": "Agent loops that run on Superserve sandboxes — a warm, isolated runtime for loop engineering.",
  "bin": {
    "superserve-loops": "install/cli.ts"
  },
  "type": "module",
  "scripts": {
    "add": "bun run install/cli.ts",
    "babysit": "bun run pr-babysitter/loop.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "bunx oxlint",
    "format": "bunx oxfmt --write",
    "format:check": "bunx oxfmt --check"
  },
  "dependencies": {
    "@superserve/sdk": "workspace:*"
  },
  "devDependencies": {
    "@superserve/typescript-config": "workspace:*",
    "@types/node": "^25.5.2",
    "typescript": "^5.7.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.18"
  }
}
