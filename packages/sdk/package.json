{
  "name": "@superserve/sdk",
  "version": "0.5.0",
  "description": "TypeScript SDK for the Superserve sandbox API",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@superserve/typescript-config": "workspace:*",
    "@types/node": "^25.5.2",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "superserve",
    "sandbox",
    "firecracker",
    "microvm",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/superserve-ai/superserve.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://superserve.ai",
  "bugs": {
    "url": "https://github.com/superserve-ai/superserve/issues"
  }
}
