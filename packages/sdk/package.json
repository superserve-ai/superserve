{
  "name": "@superserve/sdk",
  "version": "0.7.2",
  "description": "TypeScript SDK for the Superserve sandbox API",
  "keywords": [
    "firecracker",
    "microvm",
    "sandbox",
    "sdk",
    "superserve"
  ],
  "homepage": "https://superserve.ai?utm_source=npm&utm_medium=package_meta",
  "bugs": {
    "url": "https://github.com/superserve-ai/superserve/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/superserve-ai/superserve.git",
    "directory": "packages/sdk"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "bunx oxlint",
    "format": "bunx oxfmt --write",
    "format:check": "bunx oxfmt --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@superserve/typescript-config": "workspace:*",
    "@types/node": "^25.5.2",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
