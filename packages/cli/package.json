{
  "name": "@superserve/cli",
  "version": "1.1.0",
  "description": "CLI for deploying AI agents to sandboxed cloud containers",
  "keywords": [
    "agents",
    "ai",
    "cli",
    "cloud",
    "deploy",
    "sandbox"
  ],
  "homepage": "https://superserve.ai?utm_source=npm&utm_medium=package_meta",
  "bugs": {
    "url": "https://github.com/superserve-ai/superserve/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/superserve-ai/superserve.git",
    "directory": "cli"
  },
  "bin": {
    "superserve": "src/index.ts"
  },
  "files": [
    "src/"
  ],
  "type": "module",
  "scripts": {
    "dev": "echo 'CLI has no dev server use directly with bun src/index.ts'",
    "build": "bun run scripts/build.ts",
    "lint": "bunx oxlint",
    "lint:fix": "bunx oxlint --fix",
    "format": "bunx oxfmt --write",
    "format:check": "bunx oxfmt --check",
    "test": "bun test"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.0",
    "picocolors": "^1.1.1",
    "posthog-node": "^5.25.0",
    "tar-stream": "^3.1.7",
    "terminal-link": "^5.0.0"
  },
  "devDependencies": {
    "@superserve/typescript-config": "workspace:*",
    "@types/bun": "^1.2.4",
    "@types/js-yaml": "^4.0.9"
  }
}
