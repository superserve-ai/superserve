# Release-time environment variables for publishing SDKs and docs.
#
# You only need these if you're publishing from your laptop. CI already has
# them configured as GitHub Actions secrets (see README "SDKs & Docs" section).
#
# Copy to `.env.release` and fill in, then `source .env.release` before running
# any publish command. `.env.release` is gitignored.

# Fern cloud auth — used by `bun run docs:publish`.
# Get from: dashboard.buildwithfern.com → settings → API tokens
FERN_TOKEN=

# npm publish auth — used by `cd packages/sdk && bun publish`.
# Bun reads this env var (npm's standard name) for registry auth.
# Get from: npmjs.com → account settings → access tokens → automation
NPM_CONFIG_TOKEN=

# PyPI publish auth — used by `cd packages/python-sdk && uv publish`.
# Get from: pypi.org → account settings → API tokens
UV_PUBLISH_TOKEN=
