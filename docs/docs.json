{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "Superserve",
  "colors": {
    "primary": "#B2FAB4",
    "light": "#B2FAB4",
    "dark": "#B2FAB4"
  },
  "fonts": {
    "heading": {
      "family": "Instrument Sans"
