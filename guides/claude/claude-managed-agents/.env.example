# Required for the orchestrator.
ANTHROPIC_ENVIRONMENT_KEY=
ANTHROPIC_ENVIRONMENT_ID=
SUPERSERVE_API_KEY=

# Required for create_agent.py and create_environment.py (one-time setup).
# Also used by your application to create sessions.
ANTHROPIC_API_KEY=

